# Daily Tasker - Environment Variables Configuration
# ==================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ===================
# CRITICAL - Required for Production
# ===================

# Flask Secret Key (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this-in-production

# Flask Environment (development or production)
FLASK_ENV=development

# ===================
# Database Configuration
# ===================

# For Production: PostgreSQL connection URL
# Railway/Render provide this automatically as DATABASE_URL
# Leave empty to use SQLite for local development
# DATABASE_URL=postgresql://user:password@host:port/database

# ===================
# Email Configuration (Optional - only needed for daily reminders)
# ===================

# SMTP Server Settings
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# Email Credentials
# For Gmail:
# 1. Enable 2-factor authentication
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password below (NOT your regular password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here

# From Address (usually same as MAIL_USERNAME)
MAIL_FROM=your-email@gmail.com

# ===================
# Other Email Providers
# ===================

# Outlook/Hotmail:
# MAIL_SERVER=smtp-mail.outlook.com
# MAIL_PORT=587

# Yahoo:
# MAIL_SERVER=smtp.mail.yahoo.com
# MAIL_PORT=587

# SendGrid (recommended for production):
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key

# ===================
# Server Configuration
# ===================

# Port (Railway/Render set this automatically)
# PORT=5000